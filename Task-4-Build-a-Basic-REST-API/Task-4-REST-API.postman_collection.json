{
  "info": {
    "name": "Task 4 - REST API (Users)",
    "description": "CRUD operations for User entity\n\nBase URL: http://localhost:4000/api/users",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "List Users",
      "request": {
        "method": "GET",
        "url": {
          "raw": "http://localhost:4000/api/users?page=1&limit=10",
          "protocol": "http",
          "host": ["localhost"],
          "port": "4000",
          "path": ["api", "users"],
          "query": [
            { "key": "page", "value": "1" },
            { "key": "limit", "value": "10" }
          ]
        }
      }
    },
    {
      "name": "Search Users",
      "request": {
        "method": "GET",
        "url": {
          "raw": "http://localhost:4000/api/users?search=john&sortBy=name&sortOrder=asc",
          "protocol": "http",
          "host": ["localhost"],
          "port": "4000",
          "path": ["api", "users"],
          "query": [
            { "key": "search", "value": "john" },
            { "key": "sortBy", "value": "name" },
            { "key": "sortOrder", "value": "asc" }
          ]
        }
      }
    },
    {
      "name": "Filter by Age Range",
      "request": {
        "method": "GET",
        "url": {
          "raw": "http://localhost:4000/api/users?minAge=25&maxAge=40&sortBy=age",
          "protocol": "http",
          "host": ["localhost"],
          "port": "4000",
          "path": ["api", "users"],
          "query": [
            { "key": "minAge", "value": "25" },
            { "key": "maxAge", "value": "40" },
            { "key": "sortBy", "value": "age" }
          ]
        }
      }
    },
    {
      "name": "Create User",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "url": { "raw": "http://localhost:4000/api/users", "protocol": "http", "host": ["localhost"], "port": "4000", "path": ["api", "users"] },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"John Doe\",\n  \"email\": \"john@example.com\",\n  \"age\": 28\n}"
        }
      }
    },
    {
      "name": "Get User by ID",
      "request": {
        "method": "GET",
        "url": { "raw": "http://localhost:4000/api/users/:id", "protocol": "http", "host": ["localhost"], "port": "4000", "path": ["api", "users", ":id"] }
      }
    },
    {
      "name": "Full Update User (PUT)",
      "request": {
        "method": "PUT",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "url": { "raw": "http://localhost:4000/api/users/:id", "protocol": "http", "host": ["localhost"], "port": "4000", "path": ["api", "users", ":id"] },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"John Updated\",\n  \"email\": \"john.updated@example.com\",\n  \"age\": 30\n}"
        }
      }
    },
    {
      "name": "Partial Update User (PATCH)",
      "request": {
        "method": "PATCH",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "url": { "raw": "http://localhost:4000/api/users/:id", "protocol": "http", "host": ["localhost"], "port": "4000", "path": ["api", "users", ":id"] },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"age\": 35\n}"
        }
      }
    },
    {
      "name": "Delete User",
      "request": {
        "method": "DELETE",
        "url": { "raw": "http://localhost:4000/api/users/:id", "protocol": "http", "host": ["localhost"], "port": "4000", "path": ["api", "users", ":id"] }
      }
    },
    {
      "name": "Delete All Users",
      "request": {
        "method": "DELETE",
        "url": { "raw": "http://localhost:4000/api/users?confirm=true", "protocol": "http", "host": ["localhost"], "port": "4000", "path": ["api", "users"], "query": [{ "key": "confirm", "value": "true" }] }
      }
    },
    {
      "name": "API Info",
      "request": {
        "method": "GET",
        "url": { "raw": "http://localhost:4000/api", "protocol": "http", "host": ["localhost"], "port": "4000", "path": ["api"] }
      }
    }
  ]
}
